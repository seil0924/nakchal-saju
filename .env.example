# ── Supabase ─────────────────────────────────────────────
# 없으면 자동으로 인메모리 스토어로 폴백(로컬/데모). 채우면 Supabase 사용.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # ★서버 전용 · 절대 NEXT_PUBLIC_ 금지

# 없으면 결제창 대신 mock-confirm(데모). 채우면 실제 결제창.


# ── NHN KCP 표준결제 ─────────────────────────────────────
NEXT_PUBLIC_KCP_SITE_CD=ALVVY     # 낙찰사주 발급 사이트코드
NEXT_PUBLIC_KCP_TEST=0            # 1=테스트, 0=운영(실결제) — 운영 배포 시 0
KCP_CERT_INFO=                    # ★서버 전용 · 서비스 인증서(pem) 내용을 한 줄로 (BEGIN~END 포함)
